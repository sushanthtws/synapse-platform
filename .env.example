# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production

# ── API Protection ─────────────────────────────────────────────────────────────
API_SECRET=

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8080,https://sushanthtws.github.io

# ── Database ───────────────────────────────────────────────────────────────────
DB_NAME=/tmp/skills.db
BASE_SKILL_DIR=/tmp/skills

# ── GCS (production skill file storage) ──────────────────────────────────────
GCS_BUCKET=your-gcs-bucket-name

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
